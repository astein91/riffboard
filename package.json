{
  "name": "riffboard",
  "version": "0.2.0",
  "private": true,
  "description": "Conversational prototyping tool — describe an app, watch it appear",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm dev:vite\" \"pnpm dev:server\"",
    "dev:vite": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src server --ext .ts,.tsx"
  },
  "dependencies": {
    "@codesandbox/sandpack-react": "^2.19.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.0",
    "isomorphic-git": "^1.27.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
