# Clerk Auth
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Encryption key for API keys at rest (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# SQLite database path (default: ./riffboard.db)
DB_PATH=./riffboard.db

# Project data directory (default: ./data)
DATA_DIR=./data

# Google AI (Gemini) — fallback if user has no key set
GOOGLE_API_KEY=

# Deepgram — fallback for voice transcription
DEEPGRAM_API_KEY=

# Sentry — leave empty to disable
SENTRY_DSN=
VITE_SENTRY_DSN=
